    "@types/express": "^5.0.5",
    "@types/express-rate-limit": "^5.1.3",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^24.10.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.0.0",
    "nodemon": "^3.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/bcrypt": "^6.0.0",
