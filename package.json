{
  "name": "GSB-api-rest-expressjs",
  "version": "1.0.0",
  "description": "Api pour l'application GSB mobile",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --exec tsx src/server.ts",
