{
  "info": {
    "name": "GSB API - Seed BDD",
    "description": "Collection de jeu de données : supprime toutes les données existantes puis recrée motifs, visiteurs, praticiens, visites et portefeuilles.\n\n⚠️ Toutes les routes /api/* exigent un token Bearer valide.\nExécuter les dossiers dans l'ordre 0 → 7.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",      "value": "http://localhost:3000", "type": "string" },
    { "key": "token",         "value": "", "type": "string" },
    { "key": "visiteur1_id",  "value": "", "type": "string" },
    { "key": "visiteur2_id",  "value": "", "type": "string" },
    { "key": "visiteur3_id",  "value": "", "type": "string" },
    { "key": "praticien1_id", "value": "", "type": "string" },
    { "key": "praticien2_id", "value": "", "type": "string" },
    { "key": "praticien3_id", "value": "", "type": "string" },
    { "key": "motif1_id",     "value": "", "type": "string" },
    { "key": "motif2_id",     "value": "", "type": "string" },
    { "key": "motif3_id",     "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 0 - Authentification (obtenir le token)",
      "description": "⚠️ À exécuter EN PREMIER. Le token est nécessaire pour toutes les étapes suivantes y compris le nettoyage.",
      "item": [
        {
          "name": "Signup admin (si première fois)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Admin\",\n  \"prenom\": \"GSB\",\n  \"email\": \"admin.gsb@gsb.fr\",\n  \"password\": \"Admin1234!\",\n  \"tel\": \"0100000000\",\n  \"date_embauche\": \"2020-01-01\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Crée le compte admin. Ignorer l'erreur 400 si le compte existe déjà, utiliser Login à la place."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('✅ Compte admin créé, token sauvegardé');",
                  "} else {",
                  "    console.log('ℹ️ Compte existant, utiliser Login ci-dessous');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login admin (token sauvegardé automatiquement)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin.gsb@gsb.fr\",\n  \"password\": \"Admin1234!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Connexion. Le token est sauvegardé dans {{token}} pour toutes les requêtes suivantes."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Connexion réussie', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);",
                  "console.log('✅ Token sauvegardé:', json.token.substring(0, 30) + '...');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🗑️ 1 - Nettoyage BDD",
      "description": "Supprime toutes les données existantes. Requiert le token de l'étape 0.",
      "item": [
        {
          "name": "Supprimer toutes les visites",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/visites", "host": ["{{base_url}}"], "path": ["api", "visites"] },
            "description": "Récupère toutes les visites puis les supprime une par une."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (!json.data || json.data.length === 0) { console.log('✅ Aucune visite'); return; }",
                  "json.data.forEach(item => {",
                  "    pm.sendRequest({",
                  "        url: pm.collectionVariables.get('base_url') + '/api/visites/' + item._id,",
                  "        method: 'DELETE',",
                  "        header: { 'Authorization': 'Bearer ' + pm.collectionVariables.get('token') }",
                  "    }, (err, res) => console.log('🗑️ Visite supprimée:', item._id, '| Status:', res.status));",
                  "});",
                  "pm.test('Visites supprimées: ' + json.data.length, () => true);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Supprimer tous les portefeuilles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/portefeuille", "host": ["{{base_url}}"], "path": ["api", "portefeuille"] },
            "description": "Récupère toutes les relations portefeuille puis les supprime."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (!json.data || json.data.length === 0) { console.log('✅ Aucun portefeuille'); return; }",
                  "json.data.forEach(item => {",
                  "    const vId = item.visiteur?._id || item.visiteur;",
                  "    const pId = item.praticien?._id || item.praticien;",
                  "    pm.sendRequest({",
                  "        url: pm.collectionVariables.get('base_url') + '/api/portefeuille/' + vId + '/' + pId,",
                  "        method: 'DELETE',",
                  "        header: { 'Authorization': 'Bearer ' + pm.collectionVariables.get('token') }",
                  "    }, (err, res) => console.log('🗑️ Portefeuille supprimé:', vId, '/', pId, '| Status:', res.status));",
                  "});",
                  "pm.test('Portefeuilles supprimés: ' + json.data.length, () => true);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Supprimer tous les visiteurs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/visiteurs", "host": ["{{base_url}}"], "path": ["api", "visiteurs"] },
            "description": "Récupère tous les visiteurs puis les supprime un par un."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (!json.data || json.data.length === 0) { console.log('✅ Aucun visiteur'); return; }",
                  "json.data.forEach(item => {",
                  "    pm.sendRequest({",
                  "        url: pm.collectionVariables.get('base_url') + '/api/visiteurs/' + item._id,",
                  "        method: 'DELETE',",
                  "        header: { 'Authorization': 'Bearer ' + pm.collectionVariables.get('token') }",
                  "    }, (err, res) => console.log('🗑️ Visiteur supprimé:', item._id, '| Status:', res.status));",
                  "});",
                  "pm.test('Visiteurs supprimés: ' + json.data.length, () => true);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Supprimer tous les praticiens",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/praticiens", "host": ["{{base_url}}"], "path": ["api", "praticiens"] },
            "description": "Récupère tous les praticiens puis les supprime un par un."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (!json.data || json.data.length === 0) { console.log('✅ Aucun praticien'); return; }",
                  "json.data.forEach(item => {",
                  "    pm.sendRequest({",
                  "        url: pm.collectionVariables.get('base_url') + '/api/praticiens/' + item._id,",
                  "        method: 'DELETE',",
                  "        header: { 'Authorization': 'Bearer ' + pm.collectionVariables.get('token') }",
                  "    }, (err, res) => console.log('🗑️ Praticien supprimé:', item._id, '| Status:', res.status));",
                  "});",
                  "pm.test('Praticiens supprimés: ' + json.data.length, () => true);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Supprimer tous les motifs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/motifs", "host": ["{{base_url}}"], "path": ["api", "motifs"] },
            "description": "Récupère tous les motifs puis les supprime un par un."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (!json.data || json.data.length === 0) { console.log('✅ Aucun motif'); return; }",
                  "json.data.forEach(item => {",
                  "    pm.sendRequest({",
                  "        url: pm.collectionVariables.get('base_url') + '/api/motifs/' + item._id,",
                  "        method: 'DELETE',",
                  "        header: { 'Authorization': 'Bearer ' + pm.collectionVariables.get('token') }",
                  "    }, (err, res) => console.log('🗑️ Motif supprimé:', item._id, '| Status:', res.status));",
                  "});",
                  "pm.test('Motifs supprimés: ' + json.data.length, () => true);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
