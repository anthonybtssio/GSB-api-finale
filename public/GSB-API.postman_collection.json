{
  "info": {
    "name": "GSB API - Tests JWT",
    "description": "Collection pour tester l'authentification JWT et la sécurité des routes.\n\n⚠️ Toutes les routes /api/* exigent désormais un token Bearer valide.\n- /api/auth/signup et /api/auth/login : pas de token, limité à 5 req/15min\n- Toutes les autres routes : token JWT obligatoire + limité à 100 req/15min\n\nWorkflow : exécuter d'abord '🔐 Authentification > Login' pour obtenir le token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",     "value": "http://localhost:3000", "type": "string" },
    { "key": "token",        "value": "", "type": "string" },
    { "key": "visiteur_id",  "value": "", "type": "string" },
    { "key": "praticien_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Authentification (pas de token requis)",
      "description": "Routes publiques. Limitées à 5 requêtes par IP toutes les 15 minutes (anti brute-force).",
      "item": [
        {
          "name": "Signup - Créer un compte",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Dupont\",\n  \"prenom\": \"Jean\",\n  \"email\": \"jean.dupont@gsb.fr\",\n  \"password\": \"Password123!\",\n  \"tel\": \"0612345678\",\n  \"date_embauche\": \"2023-01-15\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Crée un compte visiteur. Retourne un token JWT valide 24h. Pas de token requis."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - Compte créé', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('visiteur_id', json.visiteur.id);",
                  "    console.log('✅ Token sauvegardé');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login - Se connecter (sauvegarde le token)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jean.dupont@gsb.fr\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Connexion. Le token JWT est automatiquement sauvegardé dans {{token}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Connexion réussie', () => pm.response.to.have.status(200));",
                  "pm.test('Token présent', () => pm.expect(pm.response.json()).to.have.property('token'));",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('visiteur_id', json.visiteur.id);",
                  "    console.log('✅ Token sauvegardé:', json.token.substring(0, 30) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login - Mauvais mot de passe (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jean.dupont@gsb.fr\",\n  \"password\": \"mauvais_motdepasse\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 - Identifiants incorrects', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🛡️ Tests Middleware JWT (authMiddleware actif)",
      "description": "Vérifie le comportement réel du authMiddleware sur les routes protégées.\nToutes les routes /api/* sauf /api/auth/* exigent un token Bearer valide.",
      "item": [
        {
          "name": "✅ Avec token valide - GET visiteurs (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/visiteurs",
              "host": ["{{base_url}}"],
              "path": ["api", "visiteurs"]
            },
            "description": "Token valide → 200 OK."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ 200 - Accès autorisé avec token valide', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "❌ Sans token - GET visiteurs (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/visiteurs",
              "host": ["{{base_url}}"],
              "path": ["api", "visiteurs"]
            },
            "description": "Aucun header Authorization → 401 Unauthorized request."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('❌ 401 - Accès refusé sans token', () => pm.response.to.have.status(401));",
                  "pm.test('Message Unauthorized', () => {",
                  "    pm.expect(pm.response.json().error).to.equal('Unauthorized request');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "❌ Token invalide - GET visiteurs (401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer token.invalide.ici" }],
            "url": {
              "raw": "{{base_url}}/api/visiteurs",
              "host": ["{{base_url}}"],
              "path": ["api", "visiteurs"]
            },
            "description": "Token forgé → 401 Unauthorized request."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('❌ 401 - Token invalide rejeté', () => pm.response.to.have.status(401));",
                  "pm.test('Message Unauthorized', () => {",
                  "    pm.expect(pm.response.json().error).to.equal('Unauthorized request');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "❌ Sans préfixe Bearer - GET visiteurs (401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "{{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/visiteurs",
              "host": ["{{base_url}}"],
              "path": ["api", "visiteurs"]
            },
            "description": "Token sans le préfixe 'Bearer ' → authHeader.split(' ')[1] = undefined → 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('❌ 401 - Préfixe Bearer manquant', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "✅ Avec token valide - GET praticiens (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/praticiens",
              "host": ["{{base_url}}"],
              "path": ["api", "praticiens"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ 200 - Praticiens accessibles avec token', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "❌ Sans token - GET praticiens (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/praticiens",
              "host": ["{{base_url}}"],
              "path": ["api", "praticiens"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('❌ 401 - Praticiens refusés sans token', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "👤 Visiteurs (token requis)",
