{
  "info": {
    "_postman_id": "gsb-api-collection",
    "name": "GSB API REST",
    "description": "Collection complète pour l'API REST GSB (Express + TypeScript + MongoDB).\n\n**Ordre recommandé pour commencer :**\n1. GET / (santé du serveur)\n2. POST Motifs → crée un motif (motif_id sauvegardé)\n3. POST Praticiens → crée un praticien (praticien_id sauvegardé)\n4. POST Visiteurs → crée un visiteur (visiteur_id sauvegardé)\n5. POST Visites → crée une visite (visite_id sauvegardé)\n6. POST Portefeuille → associe visiteur et praticien",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Général",
      "item": [
        {
          "name": "Accueil - Info API",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Retourne les informations générales de l'API et la liste des endpoints."
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Vérifie que le serveur est opérationnel."
          }
        }
      ]
    },
    {
      "name": "Motifs",
      "description": "Gestion des motifs de visite. Créer un motif en premier : son ID sera utilisé pour les visites.",
      "item": [
        {
          "name": "GET - Tous les motifs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_url}}/motifs",
              "host": ["{{api_url}}"],
              "path": ["motifs"]
            }
          }
        },
        {
          "name": "GET - Rechercher un motif",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_url}}/motifs/search?q=controle",
              "host": ["{{api_url}}"],
              "path": ["motifs", "search"],
              "query": [
                { "key": "q", "value": "controle" }
              ]
            }
          }
        },
        {
          "name": "GET - Motif par ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_url}}/motifs/{{motif_id}}",
              "host": ["{{api_url}}"],
              "path": ["motifs", "{{motif_id}}"]
            }
          }
        },
        {
          "name": "POST - Créer un motif",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data._id) {",
                  "    pm.environment.set('motif_id', res.data._id);",
                  "    console.log('motif_id sauvegardé :', res.data._id);",
                  "}",
                  "pm.test('Statut 201', () => pm.response.to.have.status(201));",
                  "pm.test('success = true', () => pm.expect(res.success).to.be.true);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"libelle\": \"Visite de contrôle\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{api_url}}/motifs",
              "host": ["{{api_url}}"],
              "path": ["motifs"]
            }
          }
        },
        {
          "name": "PUT - Modifier un motif",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"libelle\": \"Visite de contrôle (modifié)\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{api_url}}/motifs/{{motif_id}}",
              "host": ["{{api_url}}"],
              "path": ["motifs", "{{motif_id}}"]
            }
          }
        },
        {
          "name": "DELETE - Supprimer un motif",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{api_url}}/motifs/{{motif_id}}",
              "host": ["{{api_url}}"],
              "path": ["motifs", "{{motif_id}}"]
            }
          }
        }
      ]
    },
